    "framer-motion": "^12.34.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "mongodb": "^7.1.1",
    "multer": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
